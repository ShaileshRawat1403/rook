{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rook",
  "version": "0.1.0",
  "identifier": "com.rook.app",
  "build": {
    "beforeDevCommand": {
      "script": "pnpm dev",
      "cwd": "..",
      "wait": false
    },
    "devUrl": "http://localhost:1520",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Rook",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "visible": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false,
        "trafficLightPosition": { "x": 12, "y": 22 },
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/.rook/avatars/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": []
  }
}
